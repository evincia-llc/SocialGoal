{
  "permissions": {
    "deny": [
      "Read(**/bin/**)",
      "Read(**/obj/**)",
      "Read(**/packages/**)",
      "Read(**/TestResults/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-master.sh"
          }
        ]
      }
    ]
  }
}
